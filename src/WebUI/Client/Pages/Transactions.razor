@page "/transactions"
@inject HttpClient Http
@inject NavigationManager Navigation
@attribute [Authorize]

<div class="min-h-screen bg-gray-900 text-white p-6">
    <div class="max-w-6xl mx-auto">
        
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-4xl font-bold bg-gradient-to-r from-purple-400 to-pink-600 bg-clip-text text-transparent">
                💳 My Transactions
            </h1>
            
            <button @onclick="() => Navigation.NavigateTo(\"/game\")" class="bg-gray-800 hover:bg-gray-700 px-6 py-2 rounded-lg">
                ← Back to Game
            </button>
        </div>

        <!-- Balance Summary -->
        @if (balance != null)
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-gradient-to-br from-green-600 to-green-700 rounded-2xl p-6">
                    <p class="text-green-100 text-sm mb-1">Available Balance</p>
                    <p class="text-4xl font-bold">${balance.AvailableBalance.ToString("F4")}</p>
                </div>
                <div class="bg-gradient-to-br from-yellow-600 to-yellow-700 rounded-2xl p-6">
                    <p class="text-yellow-100 text-sm mb-1">Locked in Bets</p>
                    <p class="text-4xl font-bold">${balance.LockedBalance.ToString("F4")}</p>
                </div>
                <div class="bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl p-6">
                    <p class="text-purple-100 text-sm mb-1">Total Balance</p>
                    <p class="text-4xl font-bold">${balance.TotalBalance.ToString("F4")}</p>
                </div>
            </div>
        }

        <!-- Stats Summary -->
        @if (stats != null)
        {
            <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
                <div class="bg-green-900/30 border border-green-700 rounded-xl p-4">
                    <p class="text-green-400 text-sm mb-1">Total Deposits</p>
                    <p class="text-3xl font-bold text-green-400">${stats.TotalDeposits.ToString("F2")}</p>
                    <p class="text-xs text-gray-400 mt-1">{stats.DepositCount} transactions</p>
                </div>
                
                <div class="bg-red-900/30 border border-red-700 rounded-xl p-4">
                    <p class="text-red-400 text-sm mb-1">Total Withdrawals</p>
                    <p class="text-3xl font-bold text-red-400">${stats.TotalWithdrawals.ToString("F2")}</p>
                    <p class="text-xs text-gray-400 mt-1">{stats.WithdrawalCount} transactions</p>
                </div>
                
                <div class="bg-purple-900/30 border border-purple-700 rounded-xl p-4">
                    <p class="text-purple-400 text-sm mb-1">Fees Paid</p>
                    <p class="text-3xl font-bold text-purple-400">${stats.TotalFees.ToString("F2")}</p>
                    <p class="text-xs text-gray-400 mt-1">{stats.FeeCount} fee transactions</p>
                </div>
                
                <div class="bg-blue-900/30 border border-blue-700 rounded-xl p-4">
                    <p class="text-blue-400 text-sm mb-1">Net Flow</p>
                    <p class="text-3xl font-bold @(stats.NetFlow >= 0 ? "text-green-400" : "text-red-400")">
                        @(stats.NetFlow >= 0 ? "+" : "")${stats.NetFlow.ToString("F2")}
                    </p>
                    <p class="text-xs text-gray-400 mt-1">Deposits - Withdrawals</p>
                </div>
            </div>
        }

        <!-- Filters -->
        <div class="bg-gray-800 rounded-2xl p-6 mb-6">
            <h3 class="font-bold mb-4">🔍 Filters</h3>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label class="text-sm text-gray-400 mb-2 block">Transaction Type</label>
                    <select @bind="filterType" @bind:after="LoadTransactions" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2">
                        <option value="all">All Types</option>
                        <option value="Deposit">💳 Deposits</option>
                        <option value="Withdrawal">💸 Withdrawals</option>
                        <option value="Referral">🤝 Referral Earnings</option>
                        <option value="Bonus">🎁 Bonuses</option>
                    </select>
                </div>
                
                <div>
                    <label class="text-sm text-gray-400 mb-2 block">Status</label>
                    <select @bind="filterStatus" @bind:after="LoadTransactions" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2">
                        <option value="all">All Statuses</option>
                        <option value="Completed">✅ Completed</option>
                        <option value="Pending">⏳ Pending</option>
                        <option value="Processing">🔄 Processing</option>
                        <option value="Failed">❌ Failed</option>
                    </select>
                </div>
                
                <div>
                    <label class="text-sm text-gray-400 mb-2 block">Network</label>
                    <select @bind="filterNetwork" @bind:after="LoadTransactions" class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2">
                        <option value="all">All Networks</option>
                        <option value="POLYGON">🔷 Polygon</option>
                        <option value="TRON">⚡ Tron</option>
                        <option value="BINANCE">🟡 BSC</option>
                    </select>
                </div>
                
                <div class="flex items-end">
                    <button @onclick="LoadTransactions" class="w-full bg-purple-600 hover:bg-purple-700 px-6 py-2 rounded-lg font-semibold">
                        🔄 Refresh
                    </button>
                </div>
            </div>
        </div>

        <!-- Transactions Table -->
        <div class="bg-gray-800 rounded-2xl p-6">
            <h3 class="text-xl font-bold mb-4">Transaction History</h3>
            
            @if (isLoading)
            {
                <div class="text-center py-12">
                    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-purple-500 mx-auto"></div>
                    <p class="mt-4 text-gray-400">Loading transactions...</p>
                </div>
            }
            else if (transactions != null && transactions.Count > 0)
            {
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead class="text-left text-gray-400 border-b border-gray-700">
                            <tr>
                                <th class="pb-3">Date</th>
                                <th class="pb-3">Type</th>
                                <th class="pb-3">Network</th>
                                <th class="pb-3">Amount</th>
                                <th class="pb-3">Fee</th>
                                <th class="pb-3">Net Amount</th>
                                <th class="pb-3">Status</th>
                                <th class="pb-3">TX Hash</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in transactions)
                            {
                                <tr class="border-b border-gray-700/50 hover:bg-gray-700/30 transition">
                                    <td class="py-4 text-sm text-gray-400">
                                        @tx.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    </td>
                                    <td class="py-4">
                                        <span class="@GetTypeClass(tx.Type) px-3 py-1 rounded-full text-sm font-semibold">
                                            @GetTypeIcon(tx.Type) @tx.Type
                                        </span>
                                    </td>
                                    <td class="py-4">
                                        @if (!string.IsNullOrEmpty(tx.Network))
                                        {
                                            <span class="@GetNetworkClass(tx.Network) px-2 py-1 rounded text-xs font-semibold">
                                                @GetNetworkIcon(tx.Network) @tx.Network
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-600">-</span>
                                        }
                                    </td>
                                    <td class="py-4 font-mono font-bold text-lg">
                                        @(tx.Type == "Withdrawal" ? "-" : "+")$@tx.Amount.ToString("F4")
                                    </td>
                                    <td class="py-4">
                                        @if (tx.Fee > 0)
                                        {
                                            <span class="text-red-400 font-mono text-sm">-$@tx.Fee.ToString("F4")</span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-600">-</span>
                                        }
                                    </td>
                                    <td class="py-4 font-mono font-bold text-lg">
                                        <span class="@(GetNetAmount(tx) >= 0 ? "text-green-400" : "text-red-400")">
                                            @(GetNetAmount(tx) >= 0 ? "+" : "")$@GetNetAmount(tx).ToString("F4")
                                        </span>
                                    </td>
                                    <td class="py-4">
                                        <span class="@GetStatusClass(tx.Status) px-3 py-1 rounded-full text-xs font-semibold">
                                            @tx.Status
                                        </span>
                                    </td>
                                    <td class="py-4">
                                        @if (!string.IsNullOrEmpty(tx.BlockchainTxHash))
                                        {
                                            <a href="@GetExplorerUrl(tx)" 
                                               target="_blank" 
                                               class="text-purple-400 hover:text-purple-300 font-mono text-xs flex items-center gap-1">
                                                @tx.BlockchainTxHash.Substring(0, 8)...
                                                <span class="text-xs">🔗</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-gray-600 text-xs">
                                                @(tx.Status == "Pending" ? "Waiting..." : "-")
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-12">
                    <p class="text-gray-500 text-lg">No transactions found</p>
                    <p class="text-gray-600 text-sm mt-2">Start by depositing funds or placing bets</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool isLoading = true;
    private string filterType = "all";
    private string filterStatus = "all";
    private string filterNetwork = "all";
    private Balance? balance;
    private TransactionStats? stats;
    private List<Transaction>? transactions;

    protected override async Task OnInitializedAsync()
    {
        await LoadBalance();
        await LoadStats();
        await LoadTransactions();
    }

    private async Task LoadBalance()
    {
        try
        {
            balance = await Http.GetFromJsonAsync<Balance>("/api/wallet/balance");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading balance: {ex.Message}");
        }
    }

    private async Task LoadStats()
    {
        try
        {
            stats = await Http.GetFromJsonAsync<TransactionStats>("/api/wallet/transaction-stats");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
    }

    private async Task LoadTransactions()
    {
        isLoading = true;
        try
        {
            var url = $"/api/wallet/transactions?limit=100";
            if (filterType != "all") url += $"&type={filterType}";
            if (filterStatus != "all") url += $"&status={filterStatus}";
            if (filterNetwork != "all") url += $"&network={filterNetwork}";
            
            var response = await Http.GetFromJsonAsync<TransactionsResponse>(url);
            transactions = response?.Transactions;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading transactions: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private decimal GetNetAmount(Transaction tx)
    {
        if (tx.Type == "Withdrawal")
        {
            return -(tx.Amount + tx.Fee);
        }
        return tx.Amount - tx.Fee;
    }

    private string GetNetworkClass(string network) => network switch
    {
        "POLYGON" => "bg-purple-500/20 text-purple-400",
        "TRON" => "bg-red-500/20 text-red-400",
        "BINANCE" => "bg-yellow-500/20 text-yellow-400",
        _ => "bg-gray-500/20 text-gray-400"
    };

    private string GetNetworkIcon(string network) => network switch
    {
        "POLYGON" => "🔷",
        "TRON" => "⚡",
        "BINANCE" => "🟡",
        _ => "🌐"
    };

    private string GetExplorerUrl(Transaction tx)
    {
        if (string.IsNullOrEmpty(tx.BlockchainTxHash)) return "#";
        
        return tx.Network switch
        {
            "POLYGON" => $"https://polygonscan.com/tx/{tx.BlockchainTxHash}",
            "TRON" => $"https://tronscan.org/#/transaction/{tx.BlockchainTxHash}",
            "BINANCE" => $"https://bscscan.com/tx/{tx.BlockchainTxHash}",
            _ => $"https://polygonscan.com/tx/{tx.BlockchainTxHash}"
        };
    }

    private string GetTypeClass(string type) => type switch
    {
        "Deposit" => "bg-green-500/20 text-green-400",
        "Withdrawal" => "bg-red-500/20 text-red-400",
        "Referral" => "bg-purple-500/20 text-purple-400",
        "Bonus" => "bg-yellow-500/20 text-yellow-400",
        _ => "bg-gray-500/20 text-gray-400"
    };

    private string GetTypeIcon(string type) => type switch
    {
        "Deposit" => "⬇️",
        "Withdrawal" => "⬆️",
        "Referral" => "🤝",
        "Bonus" => "🎁",
        _ => "💳"
    };

    private string GetStatusClass(string status) => status switch
    {
        "Completed" => "bg-green-500/20 text-green-400",
        "Pending" => "bg-yellow-500/20 text-yellow-400",
        "Processing" => "bg-blue-500/20 text-blue-400",
        "Failed" => "bg-red-500/20 text-red-400",
        _ => "bg-gray-500/20 text-gray-400"
    };

    record Balance(decimal AvailableBalance, decimal LockedBalance, decimal BonusBalance, decimal TotalBalance);
    record Transaction(Guid Id, string Type, string? Network, decimal Amount, decimal Fee, string Status, string? BlockchainTxHash, DateTime CreatedAt);
    record TransactionsResponse(List<Transaction> Transactions);
    record TransactionStats(decimal TotalDeposits, int DepositCount, decimal TotalWithdrawals, int WithdrawalCount, decimal TotalFees, int FeeCount, decimal NetFlow);
}
