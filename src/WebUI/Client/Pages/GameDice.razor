@page "/game/dice"
@inject HttpClient Http
@inject IJSRuntime JS
@attribute [Authorize]

<div class="min-h-screen bg-gray-900 text-white p-6">
    <div class="max-w-7xl mx-auto">
        
        <!-- Header -->
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-3xl font-bold">🎲 Dice Game</h1>
            <div class="flex gap-4">
                <button @onclick="() => Navigation.NavigateTo(\"/game/bitcoin\")" class="bg-gray-800 px-4 py-2 rounded-lg">
                    ⚡ Play Bitcoin
                </button>
                <button @onclick="() => Navigation.NavigateTo(\"/transactions\")" class="bg-gray-800 px-4 py-2 rounded-lg">
                    💳 Transactions
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            
            <!-- Left: Dice Visualization -->
            <div class="lg:col-span-2 space-y-6">
                
                <!-- Dice Roll Display -->
                <div class="bg-gray-800 rounded-2xl p-8">
                    <div class="text-center mb-8">
                        <p class="text-sm text-gray-400 mb-2">Roll Result</p>
                        <div class="@(isRolling ? "animate-bounce" : "") inline-block">
                            <p class="text-9xl font-bold bg-gradient-to-r from-purple-400 to-pink-600 bg-clip-text text-transparent">
                                @currentRoll.ToString("F2")
                            </p>
                        </div>
                        <p class="text-sm text-gray-400 mt-2">out of 100.00</p>
                    </div>

                    <!-- Visual Number Line -->
                    <div class="relative h-20 bg-gray-900 rounded-lg overflow-hidden">
                        <!-- Gradient bar -->
                        <div class="absolute inset-0 bg-gradient-to-r from-red-600 via-yellow-500 to-green-600"></div>
                        
                        <!-- Win zone indicator -->
                        @if (rollUnder)
                        {
                            <div class="absolute left-0 top-0 bottom-0 bg-green-500/30 border-r-4 border-green-400"
                                 style="width: @(targetNumber)%">
                                <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs font-bold text-green-400">
                                    WIN
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="absolute right-0 top-0 bottom-0 bg-green-500/30 border-l-4 border-green-400"
                                 style="width: @(100 - targetNumber)%">
                                <span class="absolute left-2 top-1/2 -translate-y-1/2 text-xs font-bold text-green-400">
                                    WIN
                                </span>
                            </div>
                        }
                        
                        <!-- Current roll marker -->
                        <div class="absolute top-0 bottom-0 w-1 bg-white shadow-lg transition-all duration-500"
                             style="left: @(currentRoll)%">
                            <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-white text-gray-900 px-2 py-1 rounded text-xs font-bold whitespace-nowrap">
                                @currentRoll.ToString("F2")
                            </div>
                        </div>
                        
                        <!-- Target marker -->
                        <div class="absolute top-0 bottom-0 w-1 bg-yellow-400 opacity-50"
                             style="left: @(targetNumber)%">
                            <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 bg-yellow-400 text-gray-900 px-2 py-1 rounded text-xs font-bold">
                                @targetNumber.ToString("F2")
                            </div>
                        </div>
                    </div>

                    <!-- Result Message -->
                    @if (lastResult != null)
                    {
                        <div class="mt-8 text-center">
                            @if (lastResult.IsWin)
                            {
                                <div class="bg-green-900/30 border border-green-700 rounded-lg p-6">
                                    <p class="text-4xl font-bold text-green-400 mb-2">🎉 YOU WON!</p>
                                    <p class="text-2xl font-mono text-green-400">+$@lastResult.Payout.ToString("F2")</p>
                                    <p class="text-sm text-gray-400 mt-2">Multiplier: x@lastResult.Multiplier.ToString("F2")</p>
                                </div>
                            }
                            else
                            {
                                <div class="bg-red-900/30 border border-red-700 rounded-lg p-6">
                                    <p class="text-4xl font-bold text-red-400 mb-2">💥 YOU LOST</p>
                                    <p class="text-2xl font-mono text-red-400">-$@lastResult.Amount.ToString("F2")</p>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- How to Play -->
                <div class="bg-gray-800 rounded-2xl p-6">
                    <h3 class="text-xl font-bold mb-4">📖 How to Play</h3>
                    <div class="space-y-3 text-sm text-gray-300">
                        <p>• Set your bet amount and target number (0.00 - 100.00)</p>
                        <p>• Choose <span class="text-green-400 font-bold">Roll Under</span> or <span class="text-red-400 font-bold">Roll Over</span></p>
                        <p>• Click <strong>ROLL DICE</strong> to play</p>
                        <p>• Win if the result lands in the green zone!</p>
                        <p>• Higher risk = Higher multiplier</p>
                        <p class="text-purple-400">• <strong>Provably Fair:</strong> Every roll is verifiable</p>
                    </div>
                </div>
            </div>

            <!-- Right: Betting Panel -->
            <div class="space-y-6">
                
                <!-- Balance -->
                <div class="bg-gradient-to-br from-purple-600 to-pink-600 rounded-2xl p-6">
                    <p class="text-purple-100 text-sm mb-1">Your Balance</p>
                    <p class="text-4xl font-bold">$@balance.ToString("F2")</p>
                </div>

                <!-- Bet Configuration -->
                <div class="bg-gray-800 rounded-2xl p-6">
                    <h3 class="text-xl font-bold mb-4">⚙️ Bet Settings</h3>
                    
                    <div class="space-y-4">
                        <!-- Bet Amount -->
                        <div>
                            <label class="text-sm text-gray-400 mb-2 block">Bet Amount</label>
                            <input @bind="betAmount" type="number" step="0.01" min="0.01" max="1000"
                                   class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 text-white text-lg font-mono"
                                   placeholder="0.00" />
                            <div class="grid grid-cols-4 gap-2 mt-2">
                                <button @onclick="() => betAmount = 1" class="bg-gray-700 hover:bg-gray-600 px-2 py-2 rounded text-xs">$1</button>
                                <button @onclick="() => betAmount = 10" class="bg-gray-700 hover:bg-gray-600 px-2 py-2 rounded text-xs">$10</button>
                                <button @onclick="() => betAmount = 50" class="bg-gray-700 hover:bg-gray-600 px-2 py-2 rounded text-xs">$50</button>
                                <button @onclick="() => betAmount = 100" class="bg-gray-700 hover:bg-gray-600 px-2 py-2 rounded text-xs">$100</button>
                            </div>
                        </div>

                        <!-- Target Number -->
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <label class="text-sm text-gray-400">Target Number</label>
                                <span class="text-lg font-bold text-purple-400">@targetNumber.ToString("F2")</span>
                            </div>
                            <input @bind="targetNumber" @bind:event="oninput" @bind:after="UpdateMultiplier"
                                   type="range" min="1" max="99" step="0.01"
                                   class="w-full h-2 bg-gray-700 rounded-lg appearance-none cursor-pointer accent-purple-500" />
                            <div class="flex justify-between text-xs text-gray-500 mt-1">
                                <span>1.00</span>
                                <span>99.00</span>
                            </div>
                        </div>

                        <!-- Roll Under/Over Toggle -->
                        <div>
                            <label class="text-sm text-gray-400 mb-2 block">Prediction</label>
                            <div class="grid grid-cols-2 gap-3">
                                <button @onclick="() => { rollUnder = true; UpdateMultiplier(); }"
                                        class="@(rollUnder ? "bg-green-600" : "bg-gray-700") hover:bg-green-500 px-4 py-3 rounded-lg font-bold transition">
                                    ⬇️ Roll Under
                                </button>
                                <button @onclick="() => { rollUnder = false; UpdateMultiplier(); }"
                                        class="@(!rollUnder ? "bg-red-600" : "bg-gray-700") hover:bg-red-500 px-4 py-3 rounded-lg font-bold transition">
                                    ⬆️ Roll Over
                                </button>
                            </div>
                        </div>

                        <!-- Multiplier Display -->
                        <div class="bg-gray-900 rounded-lg p-4">
                            <div class="flex justify-between items-center">
                                <div>
                                    <p class="text-sm text-gray-400">Multiplier</p>
                                    <p class="text-3xl font-bold text-yellow-400">x@multiplier.ToString("F4")</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-gray-400">Win Chance</p>
                                    <p class="text-3xl font-bold text-green-400">@winChance.ToString("F2")%</p>
                                </div>
                            </div>
                            <div class="mt-3 pt-3 border-t border-gray-700">
                                <p class="text-sm text-gray-400">Potential Win</p>
                                <p class="text-2xl font-bold text-purple-400">$@(betAmount * multiplier).ToString("F2")</p>
                            </div>
                        </div>

                        <!-- Roll Button -->
                        <button @onclick="RollDice" disabled="@isRolling"
                                class="w-full bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-500 hover:to-pink-500 disabled:opacity-50 disabled:cursor-not-allowed px-8 py-4 rounded-xl font-bold text-xl">
                            @(isRolling ? "🎲 ROLLING..." : "🎲 ROLL DICE")
                        </button>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="bg-red-900/30 border border-red-700 rounded-lg p-3 text-red-400 text-sm">
                                ❌ @errorMessage
                            </div>
                        }
                    </div>
                </div>

                <!-- Recent Rolls -->
                <div class="bg-gray-800 rounded-2xl p-6">
                    <h3 class="text-xl font-bold mb-4">🕒 Recent Rolls</h3>
                    <div class="space-y-2 max-h-64 overflow-y-auto">
                        @foreach (var roll in recentRolls.Take(10))
                        {
                            <div class="flex items-center gap-3 bg-gray-900 rounded-lg p-3">
                                <span class="@(roll.IsWin ? "bg-green-500" : "bg-red-500") w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold">
                                    @(roll.IsWin ? "✓" : "✗")
                                </span>
                                <div class="flex-1">
                                    <p class="text-sm font-mono">Roll: @roll.Result.ToString("F2")</p>
                                    <p class="text-xs text-gray-400">@(roll.IsWin ? $"+${roll.Payout:F2}" : $"-${roll.Amount:F2}")</p>
                                </div>
                                <span class="text-xs text-gray-500">x@roll.Multiplier.ToString("F2")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    
    private decimal balance = 100.00m;
    private decimal betAmount = 10.00m;
    private decimal targetNumber = 50.00m;
    private bool rollUnder = true;
    private decimal multiplier = 1.96m;
    private decimal winChance = 49.50m;
    private decimal currentRoll = 50.00m;
    private bool isRolling = false;
    private string? errorMessage;
    
    private DiceRollResult? lastResult;
    private List<DiceRollResult> recentRolls = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadBalance();
        await LoadRecentRolls();
        UpdateMultiplier();
    }

    private async Task LoadBalance()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<BalanceResponse>("/api/wallet/balance");
            balance = response?.AvailableBalance ?? 0;
        }
        catch { }
    }

    private async Task LoadRecentRolls()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<RecentRollsResponse>("/api/game/dice/recent?limit=20");
            recentRolls = response?.Rolls ?? new();
        }
        catch { }
    }

    private void UpdateMultiplier()
    {
        // Calculate win chance
        winChance = rollUnder ? targetNumber : (100m - targetNumber);
        
        // House edge: 1%
        var houseEdge = 0.99m;
        
        // Multiplier = (100 / winChance) * houseEdge
        multiplier = (100m / winChance) * houseEdge;
    }

    private async Task RollDice()
    {
        errorMessage = null;
        
        if (betAmount <= 0 || betAmount > balance)
        {
            errorMessage = "Invalid bet amount";
            return;
        }

        isRolling = true;
        StateHasChanged();

        try
        {
            // Animate roll
            for (int i = 0; i < 10; i++)
            {
                currentRoll = new Random().Next(0, 10000) / 100m;
                StateHasChanged();
                await Task.Delay(50);
            }

            // Place bet
            var response = await Http.PostAsJsonAsync("/api/game/dice/roll", new
            {
                amount = betAmount,
                targetNumber = targetNumber,
                rollUnder = rollUnder
            });

            lastResult = await response.Content.ReadFromJsonAsync<DiceRollResult>();
            
            if (lastResult != null)
            {
                currentRoll = lastResult.Result;
                await LoadBalance();
                await LoadRecentRolls();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isRolling = false;
            StateHasChanged();
        }
    }

    record BalanceResponse(decimal AvailableBalance, decimal LockedBalance, decimal TotalBalance);
    record DiceRollResult(decimal Result, decimal Amount, decimal Multiplier, decimal Payout, bool IsWin, string ServerSeed);
    record RecentRollsResponse(List<DiceRollResult> Rolls);
}
